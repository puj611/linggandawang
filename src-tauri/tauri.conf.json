{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "linggandawang",
  "version": "0.1.0",
  "identifier": "com.linggandawang.app",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "灵感大王",
        "width": 380,
        "height": 560,
        "minWidth": 360,
        "minHeight": 400,
        "resizable": true,
        "maximizable": false,
        "minimizable": true,
        "closable": true,
        "center": true,
        "alwaysOnTop": true,
        "focus": true,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": false,
        "visible": true,
        "shadow": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https:; img-src 'self' data: blob:; font-src 'self' data:; object-src 'none'; base-uri 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
